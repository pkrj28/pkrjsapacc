<mvc:View
	xmlns:richtexteditor="sap.fe.macros.richtexteditor"
	xmlns:core="sap.ui.core" controllerName="com.pjnamespace.project1.controller.View1"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	>
	<Page id="page" title="{i18n>title}">
		<content>
		<Panel expandable="true" expanded="true">
			<f:SimpleForm title="Travel Details" editable="true" layout="ResponsiveGridLayout" labelSpanL="2" emptySpanL="6" 
																											emptySpanM="6">
				<f:content>
				<Label text="CustomerID"></Label>
				<Input id="customer"></Input>
				<Label text="Agency ID"></Label>
				<Input id="agency"></Input>
				<FlexBox justifyContent="End">
				<Button text="Go" type="Accept" icon="sap-icon://accept" press="onGo"></Button>
				<Button text="Reset" type="Reject" icon="sap-icon://reject" press="onReset"></Button>
			</FlexBox>
			</f:content>
			</f:SimpleForm>
            </Panel>
			<Table items="{/Travel}" class="sapUitinyMarginTop" id="table">
				<headerToolbar>
					<Toolbar design="Solid">
						<Title text="Travel Data for PJ"></Title>
					</Toolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Text text="Travel Id"></Text>
					</Column>
					<Column>
						<Text text="Agency ID"></Text>
					</Column>
					<Column>
						<Text text="Customer ID"></Text>
					</Column>
					<Column>
						<Text text="begin date"></Text>
					</Column>
					<Column>
						<Text text="End Date"></Text>
					</Column>
					<Column>
						<Text text="description"></Text>
					</Column>
					<Column>
						<Text text="Status"></Text>
					</Column>
				</columns>
				<items>
					<ColumnListItem type="Navigation" press="onpressrow">
						<cells>
							<Text text="{TravelId}"/>
							<Text text="{AgencyId}"/>
							<Text text="{CustomerId}"/>
                            <!-- <Text text="{BeginDate}" /> -->
							<Text text="{path:'BeginDate',formatter:'.f.formatDate'}"/>		
							<Text text="{path:'EndDate',formatter:'.f.formatDate1'}"/>		
							<!-- <Text text="{EndDate}"/> -->
							<Text text="{Description}"/>
							<Text text="{Status}"/>
							
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		
		</content>
		<footer>
			<Bar >
				<contentRight></contentRight>
			</Bar>
		</footer>
	</Page>
</mvc:View>
