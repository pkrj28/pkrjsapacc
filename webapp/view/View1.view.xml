	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	>
	<Page id="page" title="{i18n>title}">
		<content>
		<!--Multivalue UI elementcheck below  select combobox-->
<f:SimpleForm title="Multivalue UI element" editable="true" layout="ResponsiveGridLayout" labelSpanL="2" emptySpanL="5" 
emptySpanM="5">
	<f:content>
		<Label text="I am select box"></Label>
		<Select id="select" items="{oModel>/Travel}" change="onSubmit">
			<items>
				<core:Item text="{oModel>TravelId}" key="{oModel>TravelId}" ></core:Item>
			</items>
		</Select>
		<Label text="I am combo box"></Label>
		<ComboBox id="combo"  items="{oModel>/Travel}">
			<items>
				<core:Item text="{oModel>CustomerId}" ></core:Item>
			</items>
		</ComboBox>
		<Label text="I am multi combo box"></Label>
		<MultiComboBox id="multicombo"  items="{oModel>/Travel}" >
			<items>
				<core:Item text="{oModel>CustomerId}" ></core:Item>
			</items>
		</MultiComboBox>
		        <Label text="I rediobutton group"></Label>
        <RadioButtonGroup id="radio"  buttons="{oModel>/Travel}" columns="5" select="">
        <buttons>
            <RadioButton text="{oModel>/CustomerId}" />
        </buttons>
        </RadioButtonGroup >

      <Button text="Submit" type="Emphasized" press="onSubmit" ></Button>
	</f:content>
</f:SimpleForm>


	<!--Multivalue UI element End -->







